# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Get this from your Neon dashboard → Connection Details → Connection string
# Use the pooled connection string for serverless (recommended for Vercel)
#
# Format:
#   postgresql+asyncpg://<user>:<password>@<host>/<dbname>
#
# Neon gives you a URL like:
#   postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#
# Replace "postgres://" with "postgresql+asyncpg://" and drop "?sslmode=require"
# (SSL is forced separately via DATABASE_SSL=true below)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.region.aws.neon.tech/neondb

# Set to true for Neon and any hosted Postgres, false for local dev without SSL
DATABASE_SSL=true

# Optional — set to true to log SQL statements
DATABASE_ECHO=false

# ── Auth ───────────────────────────────────────────────────────────────────────
# Secret key for signing JWT tokens — generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret

# Admin account created automatically on first startup
ADMIN_EMAIL=admin
ADMIN_PASSWORD=Admin
